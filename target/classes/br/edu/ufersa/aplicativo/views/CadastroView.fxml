<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<!--
    Tela: Cadastro — Gerador de Provas
    Resolução alvo: 1280 x 750
    Mesma paleta da tela de Login
-->
<BorderPane
    prefWidth="1280"
    prefHeight="750"
    styleClass="root"
    xmlns="http://javafx.com/javafx/21"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="br.edu.ufersa.aplicativo.controlles.CadastroController">

    <center>

        <!-- ═══════════════════════════════════════
             CARD CENTRAL  (#0A4174)
             ═══════════════════════════════════════ -->
        <VBox
            styleClass="login-panel"
            alignment="CENTER"
            spacing="14"
            BorderPane.alignment="CENTER">

            <padding>
                <Insets top="40" right="40" bottom="36" left="40"/>
            </padding>

            <!-- ── TÍTULO ───────────────────────── -->
            <Label
                styleClass="title-label"
                text="GERADOR DE PROVAS"
                maxWidth="340"/>

            <!-- ── BOX CADASTRE-SE ──────────────── -->
            <StackPane styleClass="login-box">
                <Label styleClass="login-box-label" text="CADASTRE-SE"/>
            </StackPane>

            <!-- espaço -->
            <Region prefHeight="4"/>

            <!-- ── CAMPO NOME COMPLETO ──────────── -->
            <HBox styleClass="field-row" alignment="CENTER_LEFT">
                <StackPane styleClass="icon-box">
                    <!-- ícone pessoa Unicode -->
                    <Label styleClass="icon-label" text="&#9786;"/>
                </StackPane>
                <Region styleClass="field-separator"/>
                <TextField
                    fx:id="nomeField"
                    styleClass="input-text"
                    promptText="Nome completo"/>
            </HBox>

            <!-- ── CAMPO EMAIL ──────────────────── -->
            <HBox styleClass="field-row" alignment="CENTER_LEFT">
                <StackPane styleClass="icon-box">
                    <Label styleClass="icon-label" text="&#9993;"/>
                </StackPane>
                <Region styleClass="field-separator"/>
                <TextField
                    fx:id="emailField"
                    styleClass="input-text"
                    promptText="Email"/>
            </HBox>

            <!-- ── CAMPO SENHA ──────────────────── -->
            <HBox styleClass="field-row" alignment="CENTER_LEFT">
                <StackPane styleClass="icon-box">
                    <Label styleClass="icon-label" text="&#128274;"/>
                </StackPane>
                <Region styleClass="field-separator"/>
                <PasswordField
                    fx:id="senhaField"
                    styleClass="input-password"
                    promptText="Senha"/>
            </HBox>

            <!-- ── CAMPO CONFIRMAR SENHA ────────── -->
            <HBox styleClass="field-row" alignment="CENTER_LEFT">
                <StackPane styleClass="icon-box">
                    <Label styleClass="icon-label" text="&#128274;"/>
                </StackPane>
                <Region styleClass="field-separator"/>
                <PasswordField
                    fx:id="confirmarSenhaField"
                    styleClass="input-password"
                    promptText="Confirmar senha"/>
            </HBox>

            <!-- espaço antes do botão -->
            <Region prefHeight="8"/>

            <!-- ── BOTÃO CADASTRAR ──────────────── -->
            <Button
                fx:id="cadastrarButton"
                styleClass="login-button"
                text="Cadastrar"
                onAction="#handleCadastrar"/>

            <!-- ── LINK FAZER LOGIN ─────────────── -->
            <Hyperlink
                fx:id="loginLink"
                styleClass="register-link"
                text="fazer Login"
                onAction="#handleFazerLogin"/>

        </VBox>

    </center>

</BorderPane>
