<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane
        prefWidth="1280"
        prefHeight="750"
        styleClass="root-main"
        stylesheets="@../css/TelaAdicionarDiscStyle.css"
        xmlns="http://javafx.com/javafx/21"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="br.edu.ufersa.aplicativo.controlles.TelaAdicionarDiscController">

    <!-- TOPBAR -->
    <top>
        <HBox styleClass="topbar" alignment="CENTER_LEFT">
            <StackPane styleClass="topbar-brand">
                <Label styleClass="topbar-brand-label" text="Gerador de Provas"/>
            </StackPane>
            <HBox styleClass="topbar-title-area" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                <padding><Insets left="24"/></padding>
                <Label styleClass="topbar-title-label" text="Disciplinas: Adicionar Disciplina"/>
            </HBox>

            <!-- SETA DE VOLTAR -->
            <StackPane styleClass="topbar-icon-area" onMouseClicked="#handleVoltar">
                <Label styleClass="topbar-seta-label" text="←"/>
            </StackPane>

            <!-- ÍCONE CADERNO -->
            <StackPane styleClass="topbar-icon-area">
                <Label styleClass="topbar-icon-label" text="&#128209;"/>
            </StackPane>
        </HBox>
    </top>

    <!-- SIDEBAR -->
    <left>
        <VBox styleClass="sidebar" prefWidth="200" minWidth="200" maxWidth="200">
            <StackPane fx:id="menuDisciplinas" styleClass="menu-item, menu-item-selected" onMouseClicked="#handleMenuDisciplinas">
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <padding><Insets left="18"/></padding>
                    <Label styleClass="menu-icon" text="&#128209;"/>
                    <Label styleClass="menu-label" text="Disciplinas"/>
                </HBox>
            </StackPane>
            <StackPane fx:id="menuBuscar" styleClass="menu-item" onMouseClicked="#handleMenuBuscar">
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <padding><Insets left="18"/></padding>
                    <Label styleClass="menu-icon" text="&#128269;"/>
                    <Label styleClass="menu-label" text="Buscar"/>
                </HBox>
            </StackPane>
            <StackPane fx:id="menuGerarProva" styleClass="menu-item" onMouseClicked="#handleMenuGerarProva">
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <padding><Insets left="18"/></padding>
                    <Label styleClass="menu-icon" text="&#128196;"/>
                    <Label styleClass="menu-label" text="Gerar Prova"/>
                </HBox>
            </StackPane>
            <StackPane fx:id="menuRelatorio" styleClass="menu-item" onMouseClicked="#handleMenuRelatorio">
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <padding><Insets left="18"/></padding>
                    <Label styleClass="menu-icon" text="&#128202;"/>
                    <Label styleClass="menu-label" text="Relatório"/>
                </HBox>
            </StackPane>

        </VBox>
    </left>

    <!-- CENTRO -->
    <center>
        <AnchorPane styleClass="content-area">

            <!-- Card central -->
            <VBox styleClass="form-card" spacing="18"
                  AnchorPane.topAnchor="60"
                  AnchorPane.bottomAnchor="60"
                  AnchorPane.leftAnchor="200"
                  AnchorPane.rightAnchor="200">

                <!-- Cabeçalho do card -->
                <HBox alignment="CENTER_LEFT" spacing="12" styleClass="form-card-header">
                    <Label styleClass="form-card-icon" text="&#128209;+"/>
                    <Label styleClass="form-card-title" text="Adicionar Disciplina:"/>
                </HBox>

                <!-- Campos do formulário -->
                <VBox spacing="6">
                    <Label styleClass="field-label" text="Nome da disciplina:"/>
                    <TextField fx:id="fieldNome" styleClass="field-input" promptText="Ex: Matemática"/>
                </VBox>

                <VBox spacing="6">
                    <Label styleClass="field-label" text="Código da disciplina:"/>
                    <TextField fx:id="fieldCodigo" styleClass="field-input" promptText="Ex: MAT001"/>
                </VBox>

                <!-- Botão Adicionar -->
                <HBox alignment="CENTER">
                    <Button fx:id="btnAdicionar"
                            styleClass="btn-adicionar"
                            text="Adicionar"
                            onAction="#handleAdicionar"/>
                </HBox>

            </VBox>
        </AnchorPane>
    </center>

</BorderPane>